# Jotnar environment variables
# Copy this file to .env and edit as needed.
# Docker Compose automatically reads .env from the same directory.

# --- Inference ---

# URL of the inference backend.
# Full setup (docker-compose.yml): http://sglang:8000
# Server-only (docker-compose.server-only.yml): http://host.docker.internal:11434
INFERENCE_HOST=http://sglang:8000

# HTTP timeout in seconds for inference requests.
# Ollama/CPU is slower — use 300 for server-only setups.
INFERENCE_TIMEOUT_SEC=120

# Retry attempts for transient inference failures (502, 503, 504).
INFERENCE_MAX_RETRIES=3

# Concurrent screenshot interpretation workers.
# SGLang benefits from higher values (GPU batching). Ollama: keep at 1.
INFERENCE_WORKERS=4

# --- Paths ---

# SQLite database location inside the container.
JOTNAR_DB_PATH=/data/journal.db

# Server config file location inside the container.
JOTNAR_CONFIG_PATH=/data/config.yml
